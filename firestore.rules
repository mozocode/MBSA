rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tournaments/{doc} { allow read: if true; }
    match /announcements/{doc} { allow read: if true; }
    match /sponsors/{doc} { allow read: if true; }
    match /gallery/{doc} { allow read: if true; }
    match /pages/{doc} { allow read: if true; }

    match /{document=**} {
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }
  }
}
