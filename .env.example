VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=mbsa-cbbf8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mbsa-cbbf8
VITE_FIREBASE_STORAGE_BUCKET=mbsa-cbbf8.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Authorize.net Accept.js (public — safe for client)
VITE_AUTHORIZE_API_LOGIN_ID=your_api_login_id
VITE_AUTHORIZE_CLIENT_KEY=your_client_key
VITE_AUTHORIZE_SANDBOX=true

# Set in Firebase Functions secrets (not in client):
# AUTHORIZE_API_LOGIN_ID
# AUTHORIZE_TRANSACTION_KEY
# AUTHORIZE_SANDBOX=true
